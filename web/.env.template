# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored; this template is committed.
#
# Get these from your Supabase project:
#   Dashboard → Settings → Data API
#     - Project URL                              → VITE_SUPABASE_URL
#   Dashboard → Settings → API Keys
#     - "Publishable key" (starts sb_publishable_) → VITE_SUPABASE_ANON_KEY
#
# The publishable key (formerly "anon") is safe to ship in the frontend
# bundle — Row Level Security on each table is what actually protects
# your data. NEVER put the "Secret key" (sb_secret_...) in this file —
# that's server-only.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_replace_me

# ── Analytics (all optional — each is INERT if unset, and nothing loads until
#    the visitor accepts the cookie-consent banner). Set these in Cloudflare
#    Pages env PER PROJECT: real values on prod; leave the test project unset
#    (or point at separate test properties) so test traffic doesn't pollute prod.

# GA4 (gtag.js) — traffic / conversion counts. Google Analytics → Admin →
# Data streams → your web stream → "Measurement ID" (G-XXXXXXX).
VITE_GA_MEASUREMENT_ID=

# PostHog — product analytics + session replay ("where do users get stuck":
# rage clicks, funnels, recordings). PostHog → Settings → Project API Key
# (phc_...). Host is US Cloud by default; use https://eu.i.posthog.com for EU.
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
